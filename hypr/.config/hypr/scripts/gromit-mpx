#!/bin/zsh

GROMIT_MPX=/usr/bin/gromit-mpx
my_pid=$$

# Start by switching to the special workspace and firing up gromit-mpx
hyprctl dispatch 'hl.dsp.workspace.toggle_special("gromit")'
hyprctl eval "hl.exec_cmd(\"$GROMIT_MPX\")"
sleep 0.5
hyprctl eval "hl.exec_cmd(\"$GROMIT_MPX -t\")"

# Bind F9 to turn on/off gromit + the workspace
hyprctl eval "hl.bind(\"F9\", hl.dsp.workspace.toggle_special(\"gromit\"))"
hyprctl eval "hl.bind(\"F9\", function() hl.exec_cmd(\"$GROMIT_MPX -t\") end)"

# Bind F8 and Shift F8 to undo and redo
hyprctl eval "hl.bind(\"F8\", function() hl.exec_cmd(\"$GROMIT_MPX -z\") end)"
hyprctl eval "hl.bind(\"SHIFT + F8\", function() hl.exec_cmd(\"$GROMIT_MPX -y\") end)"

# Bind shift F9 to clear the screen
hyprctl eval "hl.bind(\"SHIFT + F9\", function() hl.exec_cmd(\"$GROMIT_MPX -c\") end)"

# Bind shift F9 to hide the screen
#hyprctl keyword bind "CTRL, F9, exec, $GROMIT_MPX -v"

# Bind Alt F9 to send SIGTERM to this script
hyprctl eval "hl.bind(\"ALT + F9\", function() hl.exec_cmd(\"kill -15 $my_pid\") end)"

# Run this on cleanup
wait_pid=$my_pid
cleanup() {
    echo "Performing cleanup tasks..."
    hyprctl eval "hl.exec_cmd(\"$GROMIT_MPX -q\")"
    hyprctl eval "hl.unbind(\"F8\")"
    hyprctl eval "hl.unbind(\"SHIFT + F8\")"
    hyprctl eval "hl.unbind(\"F9\")"
    hyprctl eval "hl.unbind(\"SHIFT F9\")"
    hyprctl eval "hl.unbind(\"CTRL + F9\")"
    hyprctl eval "hl.unbind(\"ALT + F9\")"
    kill -15 $wait_pid
    exit 0
}

trap cleanup SIGTERM SIGINT

# Wait until we get the signal to cleanup
sleep inf &
wait_pid=$!
wait $wait_pid
